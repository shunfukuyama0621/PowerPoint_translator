# ============================================================
# 翻訳エンジンの選択
# ============================================================
# - google         : Google翻訳（要ネット・品質◎・クラウドデプロイ向き）※デフォルト
# - libretranslate : セルフホストLibreTranslate（オフライン・機密OK）
TRANSLATION_ENGINE=google

# ============================================================
# LibreTranslateを使う場合のみ設定
# ============================================================
# ローカル起動例: libretranslate --load-only ja,en,zh
LIBRETRANSLATE_URL=http://localhost:5000

# APIキー保護モードで起動した場合のみ設定（通常は空欄でOK）
LIBRETRANSLATE_API_KEY=
